# Instagram Graph API
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_GRAPH_HOST=https://graph.facebook.com
INSTAGRAM_API_VERSION=v24.0
INSTAGRAM_TOKENS_FILE=tokens.json
INSTAGRAM_HTTP_TIMEOUT=30.0

# PostgreSQL
# Note: DatabaseConfig uses env_prefix='postgres_', so these map to host/port/db/user/password
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# TikTok Open API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_BASE_URL=https://open.tiktokapis.com/v2
TIKTOK_TOKENS_FILE=tokens2.json
TIKTOK_HTTP_TIMEOUT=30.0
TIKTOK_ACCESS_TOKEN_TTL=86400
TIKTOK_REFRESH_TOKEN_TTL=31536000
TIKTOK_REFRESH_BUFFER_HOURS=1
TIKTOK_REFRESH_INTERVAL_SECONDS=3600
TIKTOK_PROACTIVE_REFRESH_BUFFER_HOURS=2

# YouTube Data API v3 (OAuth2)
YOUTUBE_CLIENT_ID=
YOUTUBE_PROJECT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
YOUTUBE_TOKEN_URI=https://oauth2.googleapis.com/token
YOUTUBE_AUTH_PROVIDER=https://www.googleapis.com/oauth2/v1/certs
YOUTUBE_REDIRECT_URIS=
YOUTUBE_JAVASCRIPT_ORIGINS=
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.readonly
YOUTUBE_TOKENS_FILE=tokens3.json
YOUTUBE_MAX_VIDEOS_PER_PAGE=50

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=socialdas_processor
KAFKA_TOPIC_INSTAGRAM=instagram
KAFKA_TOPIC_TIKTOK=tiktok
KAFKA_TOPIC_YOUTUBE=youtube

# S3 (not yet wired)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_REGION_NAME=
